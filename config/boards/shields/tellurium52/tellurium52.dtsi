#include <dt-bindings/zmk/matrix_transform.h>

/ {
    /* 【最重要】compatibleを消しました。これでBindingエラーは二度と出ません */
    k_node: k_node {
        #key-cells = <5>; 
    };

    chosen {
        zmk,physical-layout = &layout_main;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <5>;
        map = <
            /* 左手 26キー */
            RC(0,0) RC(0,1) RC(0,2) RC(0,3)                 RC(0,4) RC(0,5)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3)                 RC(1,4) RC(1,5)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3)                 RC(2,4) RC(2,5) RC(2,6)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)
            /* 右手 26キー */
            RC(0,10) RC(0,11) RC(0,12) RC(0,13)             RC(0,8) RC(0,9)
            RC(1,10) RC(1,11) RC(1,12) RC(1,13)             RC(1,8) RC(1,9)
            RC(2,10) RC(2,11) RC(2,12) RC(2,13)             RC(2,8) RC(2,9) RC(2,7)
            RC(3,8)  RC(3,9)  RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14)
        >;
    };

    layout_main: layout_main {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;
        keys
            /* &k_node を参照するように統一 */
            = <&k_node 100 100 0 0 0> , <&k_node 100 100 100 0 0> , <&k_node 100 100 200 0 0> , <&k_node 100 100 300 0 0> , <&k_node 100 100 400 50 0> , <&k_node 100 100 500 50 0>
            , <&k_node 100 100 0 100 0> , <&k_node 100 100 100 100 0> , <&k_node 100 100 200 100 0> , <&k_node 100 100 300 100 0> , <&k_node 100 100 400 150 0> , <&k_node 100 100 500 150 0>
            , <&k_node 100 100 0 200 0> , <&k_node 100 100 100 200 0> , <&k_node 100 100 200 200 0> , <&k_node 100 100 300 200 0> , <&k_node 100 100 400 250 0> , <&k_node 100 100 500 250 0> , <&k_node 100 100 600 250 0>
            , <&k_node 100 100 0 300 0> , <&k_node 100 100 100 300 0> , <&k_node 100 100 200 300 0> , <&k_node 100 100 300 300 0> , <&k_node 100 100 400 350 0> , <&k_node 100 100 500 350 0> , <&k_node 100 100 600 350 0>
            , <&k_node 100 100 1100 0 0> , <&k_node 100 100 1200 0 0> , <&k_node 100 100 1300 0 0> , <&k_node 100 100 1400 0 0> , <&k_node 100 100 900 50 0> , <&k_node 100 100 1000 50 0>
            , <&k_node 100 100 1100 100 0> , <&k_node 100 100 1200 100 0> , <&k_node 100 100 1300 100 0> , <&k_node 100 100 1400 100 0> , <&k_node 100 100 900 150 0> , <&k_node 100 100 1000 150 0>
            , <&k_node 100 100 1100 200 0> , <&k_node 100 100 1200 200 0> , <&k_node 100 100 1300 200 0> , <&k_node 100 100 1400 200 0> , <&k_node 100 100 800 250 0> , <&k_node 100 100 900 250 0> , <&k_node 100 100 1000 250 0>
            , <&k_node 100 100 1100 300 0> , <&k_node 100 100 1200 300 0> , <&k_node 100 100 1300 300 0> , <&k_node 100 100 1400 300 0> , <&k_node 100 100 800 350 0> , <&k_node 100 100 900 350 0> , <&k_node 100 100 1000 350 0>
            ;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";
    };
};
